# Copy this file to .env and adjust as needed.
# Vite only exposes vars that start with VITE_ to the client.

# Shared mock DB hosted on https://www.npoint.io/
#
# Setup (one person on the team does this once):
#   1. Open https://www.npoint.io/
#   2. Paste the contents of src/schema/seed.json into a new bin
#   3. Save — you get a URL like https://api.npoint.io/abc123def456
#   4. Replace the placeholder URL below with the real one
#   5. Commit .env.example with the real URL so the team picks it up
#
# If unset OR left containing REPLACE_ME, src/api/client.js falls back to
# local fixtures in src/schema/seed.json so the dev server still works.
VITE_API_URL=https://api.npoint.io/f0890e623acae43039d4
